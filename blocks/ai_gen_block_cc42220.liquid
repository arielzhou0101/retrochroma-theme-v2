{% doc %}
  @prompt
    Please create a new reusable Shopify product page section for Retro Chroma called “Customer-shared close-ups”.
    
    Goal:
    Add a compact trust-building media section on product pages using product-specific customer-shared photos or close-up reference photos. This is not a testimonials/reviews section. Do not add stars, buyer names, fake quotes, “verified buyer” badges, or review counts.
    
    Default section copy:
    Heading: Customer-shared close-ups
    Body text: Photos shared after delivery, showing real-life details, lighting, and scale.
    Footer note: Shared snapshots are shown for real-life reference; colors may vary slightly by lighting.
    
    Design:
    Use small, polished image cards rather than large hero images.
    Desktop: show cards in a clean row/grid.
    Mobile: stack vertically or use a clean horizontal scroll, whichever fits the theme better.
    Use the existing theme typography, spacing, card styles, and colors.
    Keep the section visually restrained, warm, and editorial, consistent with Retro Chroma product pages.
    Image cards should have consistent aspect ratio, object-fit: cover, subtle border, and short configurable captions.
    Do not make this section look like a review carousel or a main product gallery.
    
    Configuration:
    Make the whole section fully configurable in the Shopify theme editor.
    The merchant should be able to configure:
    - section heading
    - section body text
    - optional footer note
    - card count
    - each card image
    - each card caption
    - optional card subtext
    
    Use flexible blocks for the cards, not fixed hardcoded labels.
    Support at least 1 to 6 cards.
    If possible, allow dynamic sources/metafields for each image and text field so different products can have different images and captions.
    
    Behavior:
    If no card images are configured for a product, hide the entire section.
    If only 1 or 2 cards are configured, show only those cards and keep the layout balanced.
    If more cards are configured, keep the layout clean and responsive.
    Please create this as a new theme section and do not publish theme changes automatically.
{% enddoc %}
{% liquid
  assign card_1_visible = false
  assign card_2_visible = false
  assign card_3_visible = false
  assign card_4_visible = false
  assign card_5_visible = false
  assign card_6_visible = false

  if block.settings.card_1_image != blank
    assign card_1_visible = true
  endif
  if block.settings.card_2_image != blank
    assign card_2_visible = true
  endif
  if block.settings.card_3_image != blank
    assign card_3_visible = true
  endif
  if block.settings.card_4_image != blank
    assign card_4_visible = true
  endif
  if block.settings.card_5_image != blank
    assign card_5_visible = true
  endif
  if block.settings.card_6_image != blank
    assign card_6_visible = true
  endif

  assign has_visible_cards = false
  if card_1_visible or card_2_visible or card_3_visible or card_4_visible or card_5_visible or card_6_visible
    assign has_visible_cards = true
  endif
%}

{% if has_visible_cards %}
  {% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

  {% style %}
    .customer-closeups-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
      background-color: {{ block.settings.background_color }};
      color: {{ block.settings.text_color }};
    }

    .customer-closeups-container-{{ ai_gen_id }} {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .customer-closeups-header-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment }};
      margin-bottom: 32px;
    }

    .customer-closeups-heading-{{ ai_gen_id }} {
      font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
      font-weight: {{ block.settings.heading_font.weight }};
      font-size: {{ block.settings.heading_size }}px;
      line-height: 1.2;
      margin: 0 0 12px;
      color: {{ block.settings.heading_color }};
    }

    .customer-closeups-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size }}px;
      line-height: 1.5;
      margin: 0;
      max-width: 600px;
      {% if block.settings.text_alignment == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% endif %}
    }

    .customer-closeups-grid-{{ ai_gen_id }} {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax({{ block.settings.card_min_width }}px, 1fr));
  gap: {{ block.settings.card_gap }}px;
  margin-bottom: {{ block.settings.footer_spacing }}px;
}

@media screen and (min-width: 750px) {
  .customer-closeups-grid-{{ ai_gen_id }} {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    justify-content: start;
  }

  .customer-closeups-card-{{ ai_gen_id }} {
    max-width: 100%;
  }
}


    .customer-closeups-card-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .customer-closeups-image-wrapper-{{ ai_gen_id }} {
      position: relative;
      width: 100%;
      padding-bottom: {{ block.settings.image_aspect_ratio }}%;
      overflow: hidden;
      border-radius: {{ block.settings.card_border_radius }}px;
      border: {{ block.settings.card_border_width }}px solid {{ block.settings.border_color }};
      background-color: {{ block.settings.card_background }};
    }

    .customer-closeups-image-{{ ai_gen_id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .customer-closeups-caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size }}px;
      line-height: 1.4;
      margin: 0;
      font-weight: 500;
      color: {{ block.settings.text_color }};
    }

    .customer-closeups-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size }}px;
      line-height: 1.4;
      margin: 0;
      opacity: 0.7;
      color: {{ block.settings.text_color }};
    }

    .customer-closeups-footer-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment }};
      font-size: {{ block.settings.footer_size }}px;
      line-height: 1.5;
      opacity: 0.6;
      max-width: 700px;
      color: {{ block.settings.text_color }};
      {% if block.settings.text_alignment == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% endif %}
    }

    @media screen and (max-width: 749px) {
      .customer-closeups-{{ ai_gen_id }} {
        padding: {{ block.settings.padding_top | times: 0.7 }}px 0 {{ block.settings.padding_bottom | times: 0.7 }}px;
      }

      .customer-closeups-container-{{ ai_gen_id }} {
        padding: 0 16px;
      }

      .customer-closeups-heading-{{ ai_gen_id }} {
        font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      }

      .customer-closeups-body-{{ ai_gen_id }} {
        font-size: {{ block.settings.body_size | times: 0.9 }}px;
      }

      .customer-closeups-grid-{{ ai_gen_id }} {
        {% if block.settings.mobile_layout == 'scroll' %}
          display: flex;
          overflow-x: auto;
          scroll-snap-type: x mandatory;
          gap: 16px;
          padding-bottom: 8px;
