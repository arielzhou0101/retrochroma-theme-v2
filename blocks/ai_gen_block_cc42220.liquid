  <script>
    (function() {
      class CustomerCloseups{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
        }

        connectedCallback() {
          const grid = this.querySelector('.customer-closeups-grid-{{ ai_gen_id }}');
          if (!grid) return;

          if (window.innerWidth <= 749) {
            const computedStyle = window.getComputedStyle(grid);
            if (computedStyle.overflowX === 'auto') {
              grid.addEventListener('scroll', this.handleScroll.bind(this));
            }
          }
        }

        handleScroll(event) {
          const grid = event.target;
          const scrollLeft = grid.scrollLeft;
          const scrollWidth = grid.scrollWidth;
          const clientWidth = grid.clientWidth;

          if (scrollLeft + clientWidth >= scrollWidth - 10) {
            grid.setAttribute('data-scroll-end', 'true');
          } else {
            grid.removeAttribute('data-scroll-end');
          }
        }
      }

      customElements.define('customer-closeups-{{ ai_gen_id }}', CustomerCloseups{{ ai_gen_id }});
    })();
  </script>
{% endif %}

