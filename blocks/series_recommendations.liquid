{% liquid
  assign series_product = block.settings.product
  if series_product == blank and section.settings.product != blank
    assign series_product = section.settings.product
  endif
  if series_product == blank and product != blank
    assign series_product = product
  endif
  if series_product == blank and closest.product != blank
    assign series_product = closest.product
  endif
  if request.visual_preview_mode and series_product == blank
    assign series_product = collections.all.products.first
  endif

  assign rec_title = series_product.metafields.custom.title_for_recs.value
  assign rec_collection = series_product.metafields.custom.collection_for_recs.value
%}

{% stylesheet %}
  .product-series-recs {
    width: 100%;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 14%, transparent);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-background) 94%, #f5eadc);
  }

  .product-series-recs__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
    min-height: 44px;
    padding: 12px 14px;
    cursor: pointer;
    list-style: none;
  }

  .product-series-recs__summary::-webkit-details-marker {
    display: none;
  }

  .product-series-recs__title {
    color: var(--color-foreground-heading);
    font-family: var(--font-heading--family);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.25;
  }

  .product-series-recs__chevron {
    width: 9px;
    height: 9px;
    flex: 0 0 auto;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    color: var(--color-foreground);
    transform: rotate(45deg);
    transition: transform 150ms ease;
  }

  .product-series-recs[open] .product-series-recs__chevron {
    transform: rotate(225deg);
  }

  .product-series-recs__body {
    padding: 0 14px 14px;
  }

  .product-series-recs__rail {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }

  .product-series-recs__card {
    width: clamp(138px, 32%, 150px);
    min-width: clamp(138px, 32%, 150px);
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 7px;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
    border-radius: 7px;
    background: color-mix(in srgb, var(--color-background) 88%, #fff);
    color: inherit;
    text-decoration: none;
    scroll-snap-align: start;
  }

  .product-series-recs__card:hover {
    border-color: color-mix(in srgb, var(--color-foreground) 28%, transparent);
  }

  .product-series-recs__card.is-current {
    border-color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
  }

  .product-series-recs__image-wrap {
    display: block;
    overflow: hidden;
    aspect-ratio: 1 / 1.08;
    border-radius: 5px;
    background: color-mix(in srgb, var(--color-foreground) 5%, transparent);
  }

  .product-series-recs__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-series-recs__card-text {
    display: flex;
    min-height: 58px;
    flex-direction: column;
    gap: 3px;
  }

  .product-series-recs__current {
    width: fit-content;
    color: var(--color-foreground);
    font-size: 0.66rem;
    font-weight: 600;
    line-height: 1;
  }

  .product-series-recs__card-title {
    display: -webkit-box;
    overflow: hidden;
    color: var(--color-foreground-heading);
    font-size: 0.78rem;
    line-height: 1.25;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .product-series-recs__price {
    color: color-mix(in srgb, var(--color-foreground) 78%, transparent);
    font-size: 0.74rem;
    line-height: 1.25;
  }

  @media screen and (width < 750px) {
    .product-series-recs__card {
      width: 42%;
      min-width: 42%;
    }
  }
{% endstylesheet %}

{% if series_product != blank and rec_title != blank and rec_collection != blank %}
  <div class="series-recommendations-block spacing-style" style="{% render 'spacing-style', settings: block.settings %}" {{ block.shopify_attributes }}>
    {% render 'product-series-recommendations', product: series_product %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Series recommendations",
  "tag": null,
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:settings.product"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Series recommendations",
      "category": "t:categories.product",
      "settings": {
        "product": "{{ closest.product }}"
      }
    }
  ]
}
{% endschema %}
