{% doc %}
  @prompt
    a section that duplicates the existing image with text section, enable a setting for the two buttons: can be removed, enable two settings for the image: desktop width: fit/fill/custom，mobile width: fit/fill/custom, request 1: the maximum custom desktop width of the image can be 100%, which means, if there are no elements other than the image it self, the image can take up all the horizontal space (but still keep the padding settings). request 2: fix the current image width settings. the status quo seem to be problematic, the 'custom width' setting for both desktop and mobile should be hidden if the custom is not selected. and make sure fill=100% width. these are all the same logic as the original image with text section. make sure to duplicate the original logic, request1: do not render the default fall-back image in the front-end if the image picker gets nothing. request 2: he 'custom width' setting for both desktop and mobile should be hidden if the custom is not selected. and make sure if user selected 'fill' it means 100% width.( now it seems to be set as 50% for desktop width), request 1: no border radius for image by default; request2: enable two width settings for image: desktop width and mobile width. desktop width: fit/fill/custom, when custom is selected, the range is 0-100%, mobile width is the same. default settings are both 'fill'; request 3: when there's nothing besides the image itself, the image can take up all the width within the padding limit of the block if the user sets the width to full or custom 100%. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

  {% assign has_content = false %}
    {% if block.settings.heading != blank or block.settings.text != blank %}
      {% assign has_content = true %}
    {% endif %}
    {% if block.settings.show_button and block.settings.button_label != blank %}
      {% assign has_content = true %}
    {% endif %}
    {% if block.settings.show_button_secondary and block.settings.button_secondary_label != blank %}
      {% assign has_content = true %}
    {% endif %}

  .ai-image-text-{{ ai_gen_id }} {
  display: block;
  width: 100%; /* 移动端默认全宽 */
  max-width: 100%;
  margin-left: auto;
  margin-right: auto;
  flex-shrink: 0;
  align-self: center;
}

@media screen and (min-width: 750px) {
  .ai-image-text-{{ ai_gen_id }} {
    box-sizing: border-box;
    width: clamp(420px, {{ block.settings.desktop_width_percent }}vw, 520px);
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }
}

  .ai-image-text-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.flex_direction }};
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.spacing }}px;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }


  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }
  }

  .ai-image-text-container-{{ ai_gen_id }}--reverse {
    flex-direction: row-reverse;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }}--reverse {
      flex-direction: column;
    }
  }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    {% if block.settings.image_desktop_width == 'fit' %}
      flex: 0 0 auto;
    {% elsif block.settings.image_desktop_width == 'fill' %}
      flex: 0 0 100%;
      width: 100%;
    {% else %}
      flex: 0 0 {{ block.settings.image_desktop_width_custom }}%;
      width: {{ block.settings.image_desktop_width_custom }}%;
    {% endif %}
    position: relative;
  }

  @media screen and (max-width: 749px) {
  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    {% if block.settings.image_mobile_width == 'fit' %}
      flex: 0 0 auto;
      width: auto;
    {% elsif block.settings.image_mobile_width == 'fill' %}
      flex: 0 0 100%;
      width: 100%;
    {% else %}
      flex: 0 0 {{ block.settings.image_mobile_width_custom }}%;
      width: {{ block.settings.image_mobile_width_custom }}%;
    {% endif %}
  }
}


  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  .ai-image-text-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }

  .ai-image-text-text-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-image-text-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-image-text-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_background }};
    color: {{ block.settings.button_secondary_text_color }};
    border-color: {{ block.settings.button_secondary_border_color }};
  }

  .ai-image-text-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_background }};
    color: {{ block.settings.button_secondary_hover_text_color }};
    border-color: {{ block.settings.button_secondary_hover_border_color }};
  }

  /* Text-only: no image in block */
  .ai-image-text-container-{{ ai_gen_id }}:not(:has(img)) {
    justify-content: center;
  }

  .ai-image-text-container-{{ ai_gen_id }}:not(:has(img)) .ai-image-text-content-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
    align-items: center;
  }

  .ai-image-text-container-{{ ai_gen_id }}:not(:has(img)) .ai-image-text-content-{{ ai_gen_id }},
  .ai-image-text-container-{{ ai_gen_id }}:not(:has(img)) .ai-image-text-content-{{ ai_gen_id }} *,
  .ai-image-text-container-{{ ai_gen_id }}:not(:has(img)) .metafield-rich_text_field,
  .ai-image-text-container-{{ ai_gen_id }}:not(:has(img)) .metafield-rich_text_field * {
    --text-align-default: center;
    --horizontal-alignment: center;
    text-align: center !important;
  }

  @media screen and (min-width: 750px) {
    .ai-image-text-container-{{ ai_gen_id }}:not(:has(img)) .ai-image-text-content-{{ ai_gen_id }} {
      padding-left: 80px;
      padding-right: 80px;
    }
  }
{% endstyle %}


{% assign has_image = false %}
{% if block.settings.image != blank and block.settings.image.src != blank %}
  {% assign has_image = true %}
{% endif %}

{% if has_image or has_content %}
  <div
    class="ai-image-text-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
    <div class="ai-image-text-container-{{ ai_gen_id }} {% unless has_image %}ai-image-text-no-image-{{ ai_gen_id }}{% endunless %} {% if block.settings.flex_direction == 'row' and block.settings.image_position == 'right' %}ai-image-text-container-{{ ai_gen_id }}--reverse{% endif %}
">

      {% if has_image %}
        <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image | image_url: width: 1500 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            class="ai-image-text-image-{{ ai_gen_id }}"
            style="aspect-ratio: {{ block.settings.image_aspect_ratio }};"
          >
        </div>
      {% endif %}

      {% if has_content %}
        <div class="ai-image-text-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-image-text-heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="ai-image-text-text-{{ ai_gen_id }}">
              {{ block.settings.text }}
            </div>
          {% endif %}

          {% if block.settings.show_button and block.settings.button_label != blank or block.settings.show_button_secondary and block.settings.button_secondary_label != blank %}
            <div class="ai-image-text-button-wrapper-{{ ai_gen_id }}">
              {% if block.settings.show_button and block.settings.button_label != blank %}
                <a
                  href="{{ block.settings.button_link }}"
                  class="ai-image-text-button-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_label }}
                </a>
              {% endif %}

              {% if block.settings.show_button_secondary and block.settings.button_secondary_label != blank %}
                <a
                  href="{{ block.settings.button_secondary_link }}"
                  class="ai-image-text-button-{{ ai_gen_id }} ai-image-text-button-secondary-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_secondary_label }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>

  <script>
  (function() {
    function applyNoImageClass() {
      document.querySelectorAll('[class*="ai-image-text-container-"]').forEach(function(container) {
        if (!container.querySelector('img')) {
          var classes = Array.from(container.classList);
          var containerClass = classes.find(function(c) { return c.startsWith('ai-image-text-container-'); });
          if (containerClass) {
            var id = containerClass.replace('ai-image-text-container-', '');
            container.classList.add('ai-image-text-no-image-' + id);
          }
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyNoImageClass);
    } else {
      applyNoImageClass();
    }
  })();
</script>


{% endif %}


