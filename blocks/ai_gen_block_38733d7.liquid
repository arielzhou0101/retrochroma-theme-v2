{% doc %}
  @prompt
    In the current AI-generated block inside the 仿版 Image with text section, update the image width conditional logic: when the full image width setting is selected and there are no text values (e.g., heading, text, or caption are all empty), the image should display at 100% width. When the full setting is selected but text content exists, the image should display at 50% width instead.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign has_heading = false
  assign has_text = false
  assign has_caption = false
  
  if block.settings.heading != blank
    assign has_heading = true
  endif
  
  if block.settings.text != blank
    assign has_text = true
  endif
  
  if block.settings.caption != blank
    assign has_caption = true
  endif
  
  assign has_any_text = false
  if has_heading or has_text or has_caption
    assign has_any_text = true
  endif
  
  assign image_width_class = ''
  if block.settings.image_width == 'full'
    if has_any_text
      assign image_width_class = 'ai-image-text-width-50'
    else
      assign image_width_class = 'ai-image-text-width-100'
    endif
  elsif block.settings.image_width == 'half'
    assign image_width_class = 'ai-image-text-width-50'
  elsif block.settings.image_width == 'third'
    assign image_width_class = 'ai-image-text-width-33'
  endif
%}

{% style %}
  .ai-image-text-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
    background-color: {{ block.settings.background_color }};
    width: 100%;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-image-text-width-100 {
    width: 100%;
  }

  .ai-image-text-width-50 {
    width: 50%;
  }

  .ai-image-text-width-33 {
    width: 33.333%;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-image-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-image-text-caption-{{ ai_gen_id }} {
    font-size: {{ block.settings.caption_size }}px;
    color: {{ block.settings.caption_color }};
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      width: 100% !important;
    }

    .ai-image-text-width-100,
    .ai-image-text-width-50,
    .ai-image-text-width-33 {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-image-text-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-image-wrapper-{{ ai_gen_id }} {{ image_width_class }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-image-text-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if has_any_text %}
    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if has_heading %}
        <h2 class="ai-image-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if has_text %}
        <div class="ai-image-text-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if has_caption %}
        <p class="ai-image-text-caption-{{ ai_gen_id }}">{{ block.settings.caption }}</p>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "Image width",
      "options": [
        {
          "value": "third",
          "label": "One third"
        },
        {
          "value": "half",
          "label": "Half"
        },
        {
          "value": "full",
          "label": "Full (auto-adjusts based on text)"
        }
      ],
      "default": "half",
      "info": "When 'Full' is selected: 100% width if no text, 50% width if text exists"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "row",
          "label": "Image left"
        },
        {
          "value": "row-reverse",
          "label": "Image right"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between image and text",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "text_gap",
      "label": "Gap between text elements",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "caption_size",
      "label": "Caption size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Image with text"
    }
  ]
}
{% endschema %}
