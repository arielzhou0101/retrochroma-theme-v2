{% doc %}
  @prompt
    generate a trust card, with 3 trust bullet points. every point has 1 icon image selector and 1 text.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-card-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-trust-card-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ai-trust-card-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-trust-card-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-card-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-trust-card-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-card-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-trust-card-text-{{ ai_gen_id }} {
    flex: 1;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-card-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<trust-card-{{ ai_gen_id }} class="ai-trust-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <ul class="ai-trust-card-list-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign icon_key = 'icon_' | append: i
        assign text_key = 'text_' | append: i
        assign icon = block.settings[icon_key]
        assign text = block.settings[text_key]
      %}
      
      <li class="ai-trust-card-item-{{ ai_gen_id }}">
        <div class="ai-trust-card-icon-{{ ai_gen_id }}">
          {% if icon %}
            <img
              src="{{ icon | image_url: width: 200 }}"
              alt="{{ text | escape }}"
              loading="lazy"
              width="{{ block.settings.icon_size }}"
              height="{{ block.settings.icon_size }}"
            >
          {% else %}
            <div class="ai-trust-card-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <div class="ai-trust-card-text-{{ ai_gen_id }}">
          {{ text }}
        </div>
      </li>
    {% endfor %}
  </ul>
</trust-card-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('trust-card-{{ ai_gen_id }}', TrustCard{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Trust card",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Trust point 1"
    },
    {
      "type": "image_picker",
      "id": "icon_1",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "header",
      "content": "Trust point 2"
    },
    {
      "type": "image_picker",
      "id": "icon_2",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text",
      "default": "30-day money-back guarantee"
    },
    {
      "type": "header",
      "content": "Trust point 3"
    },
    {
      "type": "image_picker",
      "id": "icon_3",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text",
      "default": "Secure checkout with SSL encryption"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Icon to text spacing",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Spacing between items",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Card padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Trust card"
    }
  ]
}
{% endschema %}
