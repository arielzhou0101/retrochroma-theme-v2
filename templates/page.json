          },
          "blocks": {}
        },
        "text_xhmmQX": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p>We look closely at material, finish, proportion, and how something feels in daily use. A new addition has to hold interest beyond the first photograph and live comfortably alongside what is already in your home.</p><p>Before shipment, each order is inspected to make sure it meets our standards.</p>",
            "width": "100%",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "paragraph",
            "font": "var(--font-body--family)",
            "font_size": "1rem",
