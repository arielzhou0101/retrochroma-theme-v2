        "text_jDKLeh": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p>We started Retro Chroma with a simple belief. A home is collected over time. It grows through instinct, memory, and the things you keep because they continue to mean something. We are not here to define a finished look. We want to help you create a home that feels personal, lived in, and open to change.</p>",
            "width": "100%",
            "max_width": "none",
            "alignment": "left",
            "type_preset": "paragraph",
            "font": "var(--font-body--family)",
            "font_size": "1rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
